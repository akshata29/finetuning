# =============================================================================
# 1-Hour Azure Fine-Tuning Demo — environment template
# =============================================================================
# Copy this file to ".env", fill in the values, then load it before running:
#
#   PowerShell:
#     Get-Content .env | Where-Object { $_ -and $_ -notmatch '^\s*#' } |
#       ForEach-Object { $k,$v = $_ -split '=',2; [Environment]::SetEnvironmentVariable($k.Trim(), $v.Trim()) }
#
#   bash/zsh:
#     set -a && source .env && set +a
#
# Then verify with:  python finetuning_demo/preflight.py
#
# SECURITY: never commit your filled-in ".env". Only this ".env.template"
# (with empty values) belongs in source control. All values are read from the
# environment only — nothing is hardcoded in the demo.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — core endpoints & identity (needed by preflight + most acts)
# -----------------------------------------------------------------------------

# Azure OpenAI / Foundry account data-plane endpoint.
# Form: https://<your-aoai-account>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# Foundry project endpoint used for the Evals API (Act 3).
# Form: https://<account>.services.ai.azure.com/api/projects/<project-name>
AZURE_AI_PROJECT_ENDPOINT=

# Control-plane identifiers for the ARM deploy of the fine-tuned model (Act 2A).
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# The Azure OpenAI / Cognitive Services account NAME (not the URL) that hosts
# your deployments — used to build the ARM resource path for deployment.
AOAI_ACCOUNT_NAME=

# Azure region of the account/project (e.g. eastus2, swedencentral).
AZURE_REGION=


# -----------------------------------------------------------------------------
# REQUIRED — models & deployment names
# -----------------------------------------------------------------------------

# Teacher model deployment used to generate synthetic transcripts (Act 1)
# and as the AI-assisted grader fallback. e.g. gpt-4.1 or gpt-4o.
TEACHER_MODEL=

# Grader model deployment for the Evals label/string-check criteria (Act 3).
# Often the same as TEACHER_MODEL. e.g. gpt-4.1 or gpt-4o.
GRADER_MODEL=

# Embedding deployment for Act 1 near-duplicate / leakage similarity checks.
# Must match an embeddings deployment in your AOAI account.
# Defaults to text-embedding-3-large if unset. e.g. text-embedding-3-small.
EMBEDDING_MODEL=text-embedding-3-large

# Deployment name you will give the fine-tuned serverless model (Act 2A deploy).
SFT_DEPLOYMENT_NAME=

# Base (un-tuned) model deployment name — the baseline arm in the 3-way eval.
# e.g. gpt-4.1-mini
BASE_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# OPTIONAL — authentication
# -----------------------------------------------------------------------------

# API key for Azure OpenAI. Leave BLANK to use Entra ID / DefaultAzureCredential
# (recommended: run `az login`). Only set this if you must use key auth.
AZURE_OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — DPO second-rung act (only if you run the preference-tuning arm)
# -----------------------------------------------------------------------------

# Deployment name for the DPO-tuned model, if/when you deploy it.
DPO_DEPLOYMENT_NAME=

# Deployment name for the RFT (reinforcement, o4-mini) model, if/when deployed.
RFT_DEPLOYMENT_NAME=


# -----------------------------------------------------------------------------
# OPTIONAL — Azure AI Language PII enrichment (Act 1 pii_scan)
# -----------------------------------------------------------------------------
# If unset, Act 1 falls back to the built-in regex PII baseline (works offline).
# Set both to enrich PII detection via Azure AI Language.
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — overrides (sensible defaults applied when unset)
# -----------------------------------------------------------------------------

# Serverless fine-tuning / deployment tier: developer | standard | globalStandard
# Default: developer
AZURE_DEPLOYMENT_TIER=developer

# Data-plane API version for fine-tuning jobs. Default: 2025-04-01-preview
AZURE_DATA_PLANE_API_VERSION=2025-04-01-preview

# Control-plane (ARM) API version for the deployment PUT. Default: 2024-10-01
AZURE_CONTROL_PLANE_API_VERSION=2024-10-01
